{
  "name": "bc-charge-app",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "scripts": {
    "predev": "node scripts/ensure-node.mjs",
    "dev": "vite",
    "predev:stripe": "node scripts/ensure-node.mjs",
    "dev:api": "node server/start.mjs",
    "dev:stripe": "npm run dev:api",
    "predev:all": "node scripts/ensure-node.mjs",
    "dev:all": "concurrently -n web,api -c cyan,green \"npm run dev\" \"npm run dev:api\"",
    "prebuild": "node scripts/ensure-node.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@stripe/react-stripe-js": "^3.10.0",
    "@stripe/stripe-js": "^7.9.0",
    "better-sqlite3": "^12.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^4.4.0",
    "express": "^4.22.2",
    "framer-motion": "^12.40.0",
    "jose": "^6.2.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.17.0",
    "nodemailer": "^8.0.10",
    "pdfkit": "^0.18.0",
    "pg": "^8.21.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.30.4",
    "stripe": "^18.5.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "postcss": "^8.5.15",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.10"
  }
}
