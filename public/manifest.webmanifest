  "shortcuts": [
    {
      "name": "Karte öffnen",
      "short_name": "Karte",
      "description": "Ladestationen in der Nähe anzeigen",
      "url": "/karte",
      "icons": [{"src": "/icons/shortcut-map.png", "sizes": "96x96"}]
    },
    {
      "name": "QR scannen",
      "short_name": "Scannen",
      "description": "Ladepunkt per QR-Code finden",
      "url": "/scan",
      "icons": [{"src": "/icons/shortcut-scan.png", "sizes": "96x96"}]
    },
    {
      "name": "Ladevorgang",
      "short_name": "Laden",
      "description": "Aktuellen Ladevorgang anzeigen",
