{
  "name": "BC Charge – Laden mit Stil",
  "short_name": "BC Charge",
  "description": "Ladestationen finden, laden und Prämien sammeln. Karte, QR-Scanner, Routenplanung und sichere Zahlung.",
  "start_url": "/",
