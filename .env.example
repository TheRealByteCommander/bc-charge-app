# ── Backend (BC Charge API) ─────────────────────────────────────────────
# Mit npm run dev:all: VITE_BC_USE_BACKEND=true + Vite-Proxy /api → 4242
VITE_BC_USE_BACKEND=true
VITE_BC_USE_PROXY=true
BC_SERVER_PORT=4242
BC_JWT_SECRET=bc_dev_jwt_secret_change_in_production_min_32_chars
# DB-Modus: sqlite (lokal) oder postgres (skalierbar)
BC_DB_CLIENT=sqlite
BC_DB_PATH=./data/bc-charge.sqlite
# Postgres (bei BC_DB_CLIENT=postgres)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bc_charge
BC_DB_POOL_MAX=20
BC_DB_POOL_IDLE_MS=30000
BC_DB_SSL=false
BC_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
BC_BIND_HOST=127.0.0.1
BC_SEED_DEMO=true

# ── Rechnungen (PDF + E-Mail) ─────────────────────────────────────────
# Absender + interne Kopie jeder Rechnung
BC_INVOICE_COPY_EMAIL=invoice@bc-charge.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=invoice@bc-charge.com
SMTP_PASS=your-smtp-password
SMTP_FROM=BC Charge <invoice@bc-charge.com>

# CitrineOS (später – nur serverseitig, nicht VITE_*)
CITRINEOS_API_URL=http://localhost:8080
CITRINEOS_HASURA_URL=http://localhost:8090/v1/graphql
CITRINEOS_HASURA_ADMIN_SECRET=
CITRINEOS_TENANT_ID=1

# Frontend: CitrineOS über Backend-Proxy (wenn VITE_BC_USE_BACKEND=true)
# Direkter Dev-Proxy nur ohne Backend-Modus:
VITE_CITRINEOS_API_URL=http://localhost:8080
VITE_CITRINEOS_HASURA_URL=http://localhost:8090/v1/graphql
VITE_CITRINEOS_TENANT_ID=1
VITE_CITRINEOS_ID_TOKEN_TYPE=Central
VITE_CITRINEOS_USE_PROXY=true

# ── Stripe ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_USE_PROXY=true

# Legacy Dev-Auth (nur wenn VITE_BC_USE_BACKEND=false)
BC_STRIPE_API_KEY=bc_dev_change_me_to_random_64_chars_minimum________________
VITE_BC_STRIPE_API_KEY=bc_dev_change_me_to_random_64_chars_minimum________________

# NIEMALS ins Frontend:
# CITRINEOS_HASURA_ADMIN_SECRET → nur als Server-Env (siehe oben)
# VITE_CITRINEOS_HASURA_ADMIN_SECRET=
